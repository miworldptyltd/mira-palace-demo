# Mira Palace — environment variables template.
# Copy to `.env` (gitignored) and fill in real values for local dev.
# Nothing here is needed to build the v1 demo — the site is fully static —
# but these are the keys future phases will need.

# Base URL the site is served from (used by the generator for canonical / OG tags)
SITE_BASE_URL=https://mi-world.github.io/mira-palace-demo

# Enquiry-form endpoint (phase-two; empty disables submission)
ENQUIRY_ENDPOINT=

# Google Maps embed key (optional; the free embed works without a key)
GOOGLE_MAPS_KEY=

# Analytics (phase-two, cookie-consent gated)
PLAUSIBLE_DOMAIN=
PLAUSIBLE_API_KEY=
